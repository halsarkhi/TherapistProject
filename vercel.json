{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd therapist-center-ui && npm install && npm run build -- --configuration production",
  "outputDirectory": "therapist-center-ui/dist/therapist-center-ui/browser",
  "installCommand": "echo 'install handled in buildCommand'",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
